</button>
</div>
</div>
</div>
</div>
<!-- Footer -->
<footer class="bg-surface-container-lowest text-outline font-label-sm text-label-sm w-full border-t border-low-contrast flex justify-between items-center h-8 px-margin-desktop">
<div class="flex gap-4">
<a class="hover:text-primary underline transition-colors cursor-pointer" href="#">Legal</a>
