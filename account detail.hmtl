                        <span class="material-symbols-outlined text-[16px]">expand_more</span>
</div>
<div class="px-3 h-8 flex items-center gap-2 bg-surface-container-high rounded border border-border-low-contrast text-label-md text-on-surface cursor-pointer hover:bg-surface-container-highest transition-colors">
                        Category: Corporate Travel
                        <span class="material-symbols-outlined text-[16px]">expand_more</span>
</div>
<div class="flex-1"></div>
<div class="flex items-center gap-1">
<button class="w-8 h-8 flex items-center justify-center text-on-surface-variant hover:text-primary transition-colors">
<span class="material-symbols-outlined">filter_list</span>
</button>
<button class="w-8 h-8 flex items-center justify-center text-on-surface-variant hover:text-primary transition-colors">
<span class="material-symbols-outlined">search</span>
</button>
</div>
</div>
<!-- Data Table -->
<div class="overflow-x-auto custom-scrollbar">
<table class="w-full text-left border-collapse min-w-[800px] high-density-table">
<thead>
<tr class="border-b border-border-low-contrast bg-surface-container-lowest">
<th class="px-4 py-2 font-label-sm text-label-sm text-outline uppercase tracking-wider w-12 text-center">
<input class="rounded-sm bg-surface-container-high border-border-low-contrast text-primary focus:ring-0" type="checkbox"/>
</th>
<th class="px-4 py-2 font-label-sm text-label-sm text-outline uppercase tracking-wider">Date</th>
<th class="px-4 py-2 font-label-sm text-label-sm text-outline uppercase tracking-wider">Merchant / Description</th>
<th class="px-4 py-2 font-label-sm text-label-sm text-outline uppercase tracking-wider">Category</th>
<th class="px-4 py-2 font-label-sm text-label-sm text-outline uppercase tracking-wider">Status</th>
<th class="px-4 py-2 font-label-sm text-label-sm text-outline uppercase tracking-wider text-right">Amount</th>
</tr>
</thead>
<tbody class="font-data-display text-[13px]">
