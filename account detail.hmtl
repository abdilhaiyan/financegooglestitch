</tbody>
</table>
</div>
<!-- Table Footer -->
<div class="px-4 py-2 border-t border-border-low-contrast flex items-center justify-between text-label-sm text-outline">
<div>Showing 1-15 of 244 transactions</div>
<div class="flex items-center gap-2">
<button class="w-6 h-6 flex items-center justify-center rounded border border-border-low-contrast hover:bg-surface-container-highest transition-colors">
