<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Ledger Pro - Amex Platinum</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;family=JetBrains+Mono:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<!-- Tailwind Config Verbatim from Design System -->
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "surface-container-high": "#262b2d",
                    "on-surface": "#e0e3e6",
                    "border-low-contrast": "#334155",
                    "tertiary-container": "#be5400",
                    "outline-variant": "#464555",
                    "on-primary-fixed-variant": "#321ed2",
                    "error": "#ffb4ab",
                    "on-secondary-fixed": "#001c37",
                    "on-secondary": "#19324d",
                    "background": "#101416",
                    "outline": "#918fa1",
                    "surface-container-low": "#181c1e",
                    "on-error-container": "#ffdad6",
                    "error-container": "#93000a",
                    "status-info": "#0EA5E9",
                    "on-primary": "#1d00a5",
                    "on-secondary-container": "#9fb7d9",
                    "secondary": "#b0c8eb",
                    "on-primary-fixed": "#0f0069",
                    "status-expense": "#EF4444",
                    "on-tertiary-container": "#fffaf9",
                    "secondary-fixed-dim": "#b0c8eb",
                    "secondary-container": "#314865",
                    "tertiary": "#ffb68f",
                    "tertiary-fixed-dim": "#ffb68f",
                    "surface-bright": "#363a3c",
                    "inverse-surface": "#e0e3e6",
                    "surface-variant": "#313538",
                    "status-income": "#10B981",
                    "on-error": "#690005",
                    "surface-slate": "#1E293B",
                    "on-primary-container": "#fefaff",
                    "inverse-primary": "#4c42e9",
                    "on-tertiary-fixed-variant": "#773200",
                    "inverse-on-surface": "#2d3133",
                    "tertiary-fixed": "#ffdbca",
                    "surface-container": "#1c2023",
                    "on-tertiary": "#542100",
                    "surface-tint": "#c3c0ff",
                    "primary-container": "#635bff",
                    "primary-fixed": "#e2dfff",
                    "surface": "#101416",
                    "surface-dim": "#101416",
                    "secondary-fixed": "#d2e4ff",
                    "on-surface-variant": "#c7c4d8",
                    "on-secondary-fixed-variant": "#314865",
                    "on-tertiary-fixed": "#331100",
                    "surface-container-highest": "#313538",
                    "primary-fixed-dim": "#c3c0ff",
                    "primary": "#c3c0ff",
                    "surface-container-lowest": "#0b0f11",
                    "on-background": "#e0e3e6"
            },
            "borderRadius": {
                    "DEFAULT": "0.125rem",
                    "lg": "0.25rem",
                    "xl": "0.5rem",
                    "full": "0.75rem"
            },
            "spacing": {
                    "compact-padding": "8px",
                    "unit": "4px",
                    "margin-mobile": "16px",
                    "table-row-height": "32px",
                    "margin-desktop": "32px",
                    "gutter": "16px"
            },
            "fontFamily": {
                    "headline-sm": ["Inter"],
                    "data-display": ["JetBrains Mono"],
                    "label-md": ["JetBrains Mono"],
                    "label-sm": ["JetBrains Mono"],
                    "headline-md": ["Inter"],
                    "body-lg": ["Inter"],
                    "body-md": ["Inter"],
                    "headline-lg": ["Inter"],
                    "body-sm": ["Inter"]
            },
            "fontSize": {
                    "headline-sm": ["18px", {"lineHeight": "24px", "fontWeight": "600"}],
                    "data-display": ["14px", {"lineHeight": "20px", "letterSpacing": "-0.01em", "fontWeight": "600"}],
                    "label-md": ["12px", {"lineHeight": "16px", "letterSpacing": "0.02em", "fontWeight": "500"}],
                    "label-sm": ["10px", {"lineHeight": "14px", "letterSpacing": "0.04em", "fontWeight": "500"}],
                    "headline-md": ["24px", {"lineHeight": "32px", "letterSpacing": "-0.01em", "fontWeight": "600"}],
                    "body-lg": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                    "body-md": ["14px", {"lineHeight": "20px", "fontWeight": "400"}],
                    "headline-lg": ["32px", {"lineHeight": "40px", "letterSpacing": "-0.02em", "fontWeight": "600"}],
                    "body-sm": ["13px", {"lineHeight": "18px", "fontWeight": "400"}]
            }
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        body {
            background-color: #101416;
            color: #e0e3e6;
            -webkit-font-smoothing: antialiased;
        }
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
            height: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: #101416;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #334155;
            border-radius: 2px;
        }
        .high-density-table tr {
            height: 32px;
        }
    </style>
</head>
<body class="font-body-md text-body-md">
<!-- SideNavBar -->
<nav class="bg-surface-container dark:bg-surface-container font-label-md text-label-md fixed left-0 top-0 h-full w-64 border-r border-low-contrast flex flex-col p-compact-padding gap-unit">
<div class="px-4 py-6 flex items-center gap-3">
<div class="w-8 h-8 bg-primary rounded flex items-center justify-center">
<span class="material-symbols-outlined text-on-primary" style="font-variation-settings: 'FILL' 1;">account_balance</span>
</div>
<div>
<div class="font-headline-md text-headline-md font-black text-on-surface">Ledger Pro</div>
<div class="text-outline text-label-sm">Institutional Grade</div>
</div>
</div>
<div class="flex-1 mt-4 space-y-1">
<a class="flex items-center gap-3 px-4 py-2 text-on-surface-variant hover:text-on-surface hover:bg-surface-container-high transition-all" href="#">
<span class="material-symbols-outlined">dashboard</span>
                Dashboard
            </a>
<a class="flex items-center gap-3 px-4 py-2 text-primary bg-secondary-container rounded scale-95 transition-transform" href="#">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">account_balance</span>
                Accounts
            </a>
<a class="flex items-center gap-3 px-4 py-2 text-on-surface-variant hover:text-on-surface hover:bg-surface-container-high transition-all" href="#">
<span class="material-symbols-outlined">receipt_long</span>
                Transactions
            </a>
<a class="flex items-center gap-3 px-4 py-2 text-on-surface-variant hover:text-on-surface hover:bg-surface-container-high transition-all" href="#">
<span class="material-symbols-outlined">assessment</span>
                Reports
            </a>
<a class="flex items-center gap-3 px-4 py-2 text-on-surface-variant hover:text-on-surface hover:bg-surface-container-high transition-all" href="#">
<span class="material-symbols-outlined">settings</span>
                Settings
            </a>
</div>
<button class="m-4 bg-primary-container text-on-primary-container font-label-md py-3 rounded flex items-center justify-center gap-2 hover:opacity-90 transition-opacity">
<span class="material-symbols-outlined">add</span>
            New Transaction
        </button>
</nav>
<!-- Main Canvas -->
<main class="ml-64 flex flex-col min-h-screen">
<!-- TopAppBar -->
<header class="bg-surface dark:bg-surface text-primary font-body-md border-b border-low-contrast flex justify-between items-center h-12 px-margin-desktop w-full">
<div class="flex items-center gap-4">
<span class="font-headline-sm text-headline-sm font-bold">Ledger</span>
<div class="h-4 w-[1px] bg-border-low-contrast mx-2"></div>
<div class="flex items-center gap-2 text-on-surface-variant">
<span class="material-symbols-outlined text-[18px]">search</span>
<input class="bg-transparent border-none focus:ring-0 text-body-sm w-64" placeholder="Search transactions..." type="text"/>
</div>
</div>
<div class="flex items-center gap-6">
<div class="flex items-center gap-4">
<span class="material-symbols-outlined cursor-pointer hover:bg-surface-container-highest transition-colors p-1 rounded">notifications</span>
<span class="material-symbols-outlined cursor-pointer hover:bg-surface-container-highest transition-colors p-1 rounded">help_outline</span>
</div>
<div class="flex items-center gap-2 cursor-pointer">
<img class="w-8 h-8 rounded-full border border-low-contrast object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCqfquecf-NUCAaGK_yqavKHRJGLBoXxXjOKkQ0GKCOd6G0GD4ZbPzXXu0_zmtnPkXuPiKHXoS8zIN_RxsKubMeNrPh5txsCZetO11-V9Xn-3i_NkhOun3IwM1caBt9ciKIFPfxANKwpYMgtDWPD579ZF3JYBkDAB5GkAyeENnP6Db6SV6tdLS6VwnQCzeDKd-h3mGveoLDLKMr8sTbVcpdu0BzSlQNclN5FypVyGXV8-HXa5qpJ1vDRrHlVJxrEiGINoIj7HKjx5C2"/>
</div>
</div>
</header>
<!-- Content Area -->
<div class="p-margin-desktop space-y-gutter flex-1">
<!-- Account Header & Action Bar -->
<div class="flex flex-col md:flex-row md:items-end justify-between gap-gutter">
<div class="space-y-unit">
<div class="flex items-center gap-3">
<h1 class="font-headline-lg text-headline-lg tracking-tight">Amex Platinum</h1>
<span class="px-2 py-0.5 bg-surface-container-highest text-on-surface text-label-sm rounded uppercase tracking-wider font-semibold border border-border-low-contrast">Corporate</span>
</div>
<p class="text-on-surface-variant font-body-md">Account ending in •••• 1007</p>
</div>
<div class="flex items-center gap-compact-padding">
<button class="h-8 px-4 flex items-center gap-2 bg-surface-container-high border border-border-low-contrast text-label-md rounded hover:bg-surface-container-highest transition-colors">
<span class="material-symbols-outlined text-[18px]">file_upload</span>
                        Import Statement
                    </button>
<button class="h-8 px-4 flex items-center gap-2 bg-surface-container-high border border-border-low-contrast text-label-md rounded hover:bg-surface-container-highest transition-colors">
<span class="material-symbols-outlined text-[18px]">file_download</span>
                        Export Data
                    </button>
<button class="h-8 px-4 flex items-center gap-2 bg-primary-container text-on-primary-container text-label-md rounded hover:opacity-90 transition-opacity">
<span class="material-symbols-outlined text-[18px]">sync</span>
                        Reconcile
                    </button>
</div>
</div>
<!-- Bento Grid - Account Metrics -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-gutter">
<!-- Balance Card -->
<div class="md:col-span-2 p-6 bg-surface-container rounded border border-border-low-contrast flex flex-col justify-between">
<div>
<div class="flex justify-between items-start mb-4">
<span class="text-label-md text-on-surface-variant">Current Balance</span>
<span class="material-symbols-outlined text-primary">account_balance_wallet</span>
</div>
<div class="font-headline-lg text-headline-lg font-data-display text-on-surface">$12,458.20</div>
<div class="mt-4 flex items-center gap-6">
<div class="flex flex-col">
<span class="text-label-sm text-outline uppercase tracking-tighter">Cleared Funds</span>
<span class="font-data-display text-status-income text-lg">$11,890.50</span>
</div>
<div class="w-[1px] h-10 bg-border-low-contrast"></div>
<div class="flex flex-col">
<span class="text-label-sm text-outline uppercase tracking-tighter">Pending Debits</span>
<span class="font-data-display text-on-surface-variant text-lg">$567.70</span>
</div>
</div>
</div>
</div>
<!-- Reconciliation Card -->
<div class="p-6 bg-surface-container rounded border border-border-low-contrast flex flex-col justify-between">
<div>
<div class="flex justify-between items-start mb-4">
<span class="text-label-md text-on-surface-variant">Reconciliation Status</span>
<span class="material-symbols-outlined text-status-income" style="font-variation-settings: 'FILL' 1;">check_circle</span>
</div>
<div class="text-headline-sm font-headline-sm text-on-surface">Oct 24, 2024</div>
<p class="text-label-sm text-on-surface-variant mt-1">Status: <span class="text-status-income font-bold">RECONCILED</span></p>
</div>
<div class="mt-4">
<div class="flex justify-between text-label-sm mb-1 text-outline">
<span>Accuracy</span>
<span>92%</span>
</div>
<div class="h-1.5 w-full bg-surface-container-highest rounded-full overflow-hidden">
<div class="h-full bg-status-income w-[92%]"></div>
</div>
</div>
</div>
<!-- Expense Limit Card -->
<div class="p-6 bg-surface-container rounded border border-border-low-contrast flex flex-col justify-between">
<div>
<div class="flex justify-between items-start mb-4">
<span class="text-label-md text-on-surface-variant">Monthly Volume</span>
<span class="material-symbols-outlined text-status-expense">monitoring</span>
</div>
<div class="text-headline-sm font-headline-sm text-on-surface">$8,122.00</div>
<p class="text-label-sm text-on-surface-variant mt-1">Trend: <span class="text-status-expense font-bold">+4.2%</span></p>
</div>
<div class="flex items-end gap-1 h-8 mt-4">
<div class="flex-1 bg-primary/10 h-2 rounded-t-sm"></div>
<div class="flex-1 bg-primary/20 h-4 rounded-t-sm"></div>
<div class="flex-1 bg-primary/40 h-3 rounded-t-sm"></div>
<div class="flex-1 bg-primary/60 h-6 rounded-t-sm"></div>
<div class="flex-1 bg-primary/30 h-4 rounded-t-sm"></div>
<div class="flex-1 bg-primary/80 h-5 rounded-t-sm"></div>
<div class="flex-1 bg-primary h-8 rounded-t-sm"></div>
</div>
</div>
</div>
<!-- Transaction List Section -->
<div class="bg-surface-container rounded border border-border-low-contrast flex flex-col">
<!-- Filters Bar -->
<div class="px-4 py-2 border-b border-border-low-contrast flex flex-wrap items-center gap-2 bg-surface-container-low">
<div class="px-3 h-8 flex items-center gap-2 bg-surface-container-high rounded border border-border-low-contrast text-label-md text-on-surface cursor-pointer hover:bg-surface-container-highest transition-colors">
                        Oct 1 - Oct 31
                        <span class="material-symbols-outlined text-[16px]">expand_more</span>
</div>
<div class="px-3 h-8 flex items-center gap-2 bg-surface-container-high rounded border border-border-low-contrast text-label-md text-on-surface cursor-pointer hover:bg-surface-container-highest transition-colors">
