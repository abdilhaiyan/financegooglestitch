</td>
<td class="px-4 py-1 text-right text-on-surface">-$2,140.00</td>
</tr>
<tr class="border-b border-border-low-contrast/30 hover:bg-surface-container-high transition-colors">
<td class="px-4 py-1 text-center">
<input class="rounded-sm bg-surface-container-high border-border-low-contrast text-primary focus:ring-0" type="checkbox"/>
</td>
<td class="px-4 py-1 text-on-surface-variant">OCT 23</td>
<td class="px-4 py-1 font-medium">Lufthansa Airways</td>
<td class="px-4 py-1">
<span class="px-2 py-0.5 rounded-sm bg-surface-container-highest border border-border-low-contrast text-[10px] uppercase font-bold text-on-surface-variant">Travel</span>
</td>
<td class="px-4 py-1">
<div class="flex items-center gap-2 text-status-income">
<span class="material-symbols-outlined text-[14px]">check_circle</span>
                                        CLEARED
                                    </div>
</td>
<td class="px-4 py-1 text-right text-on-surface">-$1,822.40</td>
</tr>
<tr class="border-b border-border-low-contrast/30 hover:bg-surface-container-high transition-colors bg-surface-container-lowest/10">
<td class="px-4 py-1 text-center">
<input class="rounded-sm bg-surface-container-high border-border-low-contrast text-primary focus:ring-0" type="checkbox"/>
</td>
<td class="px-4 py-1 text-on-surface-variant">OCT 21</td>
<td class="px-4 py-1 font-medium">AMEX Membership Rewards Refund</td>
<td class="px-4 py-1">
